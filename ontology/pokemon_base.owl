<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://ic.esame.it/pokemon.owl"
         xmlns="http://ic.esame.it/pokemon.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://ic.esame.it/pokemon.owl"/>

<owl:ObjectProperty rdf:about="#has_type">
  <rdfs:domain rdf:resource="#Pokemon"/>
  <rdfs:range rdf:resource="#Type"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_role">
  <rdfs:domain rdf:resource="#Pokemon"/>
  <rdfs:range rdf:resource="#Role"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_weak_to">
  <rdfs:domain rdf:resource="#Type"/>
  <rdfs:range rdf:resource="#Type"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_immune_to">
  <rdfs:domain rdf:resource="#Type"/>
  <rdfs:range rdf:resource="#Type"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_vulnerability">
  <owl:propertyChainAxiom>
    <rdf:Description>
      <rdf:first rdf:resource="#has_type"/>
      <rdf:rest>
        <rdf:Description>
          <rdf:first rdf:resource="#is_weak_to"/>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </owl:propertyChainAxiom>
  <rdfs:domain rdf:resource="#Pokemon"/>
  <rdfs:range rdf:resource="#Type"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_immunity">
  <owl:propertyChainAxiom>
    <rdf:Description>
      <rdf:first rdf:resource="#has_type"/>
      <rdf:rest>
        <rdf:Description>
          <rdf:first rdf:resource="#is_immune_to"/>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </owl:propertyChainAxiom>
  <rdfs:domain rdf:resource="#Pokemon"/>
  <rdfs:range rdf:resource="#Type"/>
</owl:ObjectProperty>

